# Passwall-Sub-Panel main config example.
# Copy to config.yaml and fill in jwt_secret (or set PSP_JWT_SECRET).
# Database is zero-config by default: if mysql.dsn is omitted or empty, the
# panel uses SQLite at <data_dir>/panel.db.
#
# All other settings (sub_base_url, cron cadence, JWT TTLs, rate limits,
# login mode, new-user defaults, etc.) are stored in the database and
# managed via Admin -> Settings. They are NOT read from this file.

listen: ":8788"

# Reverse proxy client IP handling:
#   PSP_TRUSTED_PROXIES="127.0.0.1,::1"   # default, local reverse proxy only
#   PSP_TRUSTED_PROXIES="none"            # ignore forwarded client IP headers
# Add your proxy/container gateway CIDRs here when running behind a non-local
# reverse proxy so audit logs and per-IP rate limits use the real client IP.

# Generate (PowerShell):
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | % {[char]$_})
# or set env PSP_JWT_SECRET instead.
jwt_secret: "CHANGE-ME-TO-RANDOM-48-CHAR-STRING"

# Separate key for encrypting database secrets at rest. Keep it stable; losing
# it prevents decrypting saved 3X-UI/OIDC/SAML/SMTP credentials.
# Env override: PSP_ENCRYPTION_KEY.
encryption_key: "CHANGE-ME-TO-RANDOM-48-CHAR-STRING"

# YAML config directory (templates).
config_dir: "./config"

# Runtime data dir. With the default SQLite setup, the DB file is:
#   ./data/panel.db
data_dir: "./data"

# Optional database connection.
#
# Default: leave the whole mysql block commented out to use embedded SQLite
# at <data_dir>/panel.db. Zero-config, no extra setup needed.
#
# To use a custom SQLite file path:
# mysql:
#   dsn: "sqlite:./data/my-custom.db"
#
# To use MySQL, uncomment and fill in the fields below:
#
# mysql:
#   host: "127.0.0.1"        # MySQL server hostname or IP
#   port: 3306               # TCP port (default 3306)
#   user: "psp"              # MySQL username
#   password: "your_password"
#   database: "passwall"     # database name (must already exist)
#   # params: ""             # extra DSN params; blank uses the safe default
#                            # (parseTime=true&charset=utf8mb4&loc=Local)
#
# Advanced: set dsn to a raw go-sql-driver string when discrete fields
# don't fit (unix socket, TLS, multi-host, etc.). When set, dsn wins
# over the discrete fields above.
#   dsn: "user:pw@unix(/tmp/mysql.sock)/db?parseTime=true"
#
# Env override: PSP_MYSQL_DSN replaces everything in this block.
