# 3X-UI panel credentials.
#
# Copy to:
#   ./config/xui_panels.yaml
#
# Linux production recommendation:
#   chmod 0600 ./config/xui_panels.yaml
#
# Each entry registers one 3X-UI panel. Nodes are linked to a panel by `name`.
# Auth priority:
#   - api_token (Bearer)  -> preferred, no login round-trip
#   - username + password -> fallback, the client logs in and caches the cookie
#
# Sensitive fields may be AES-GCM encrypted. To do so, prefix the value with
# "enc:" and supply the AES key via env PSP_SECRET_KEY. The CLI tool ships a
# `psp-cli encrypt` helper to produce the prefixed string.

# Default: no panels configured yet. The app can start with this.
panels: []

# Example 1: API token auth (preferred).
#
# panels:
#   - name: default
#     url: "https://xui.example.com:54321"
#     api_token: "PASTE_3X_UI_API_TOKEN_HERE"
#     username: ""
#     password: ""
#     remark: "Primary 3X-UI panel"

# Example 2: username/password auth.
#
# panels:
#   - name: default
#     url: "https://xui.example.com:54321"
#     api_token: ""
#     username: "admin"
#     password: "CHANGE_ME"
#     remark: "Primary 3X-UI panel"

# Example 3: encrypted password.
#
# First generate encrypted text:
#   $env:PSP_SECRET_KEY="12345678901234567890123456789012"
#   .\psp-cli.exe encrypt --value "your-3x-ui-password"
#
# Then use the printed enc:... value:
#
# panels:
#   - name: default
#     url: "https://xui.example.com:54321"
#     api_token: ""
#     username: "admin"
#     password: "enc:BASE64-AES-GCM-CIPHERTEXT-HERE"
#     remark: "Primary 3X-UI panel"

# Example 4: multiple panels.
#
# panels:
#   - name: us-west
#     url: "https://us-west-xui.example.com:54321"
#     api_token: "US_WEST_TOKEN"
#     username: ""
#     password: ""
#     remark: "US West"
#   - name: jp-tokyo
#     url: "https://jp-tokyo-xui.example.com:54321"
#     api_token: "JP_TOKYO_TOKEN"
#     username: ""
#     password: ""
#     remark: "Japan Tokyo"
