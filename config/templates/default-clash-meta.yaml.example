# Clash Meta subscription template example.
#
# Copy to:
#   ./config/templates/default-clash-meta.yaml
#
# The `content` block below is a complete working template. You usually only
# need to edit proxy-groups and rules.

slug: default-clash-meta
name: Default Clash Meta
client_type: clash-meta
is_default: true
content: |
  # Generated by Passwall-Sub-Panel.
  # Placeholders:
  #   {{ proxies }}        — replaced with the user's authorised proxy list
  #   {{ rules_common }}   — concatenated rule_sets the user has enabled
  #   {{ rules_personal }} — the user's personal rules
  # In proxy-groups, "@all" / "@region:XX" / "@tag:YY" expand to lists of node names.

  mixed-port: 7890
  allow-lan: true
  bind-address: '*'
  mode: rule
  log-level: info
  unified-delay: true
  tcp-concurrent: true
  find-process-mode: strict

  dns:
    enable: true
    listen: :53
    ipv6: true
    enhanced-mode: fake-ip
    fake-ip-range: 198.18.0.1/16
    default-nameserver:
      - 223.5.5.5
      - 119.29.29.29
    nameserver:
      - https://dns.alidns.com/dns-query
      - https://doh.pub/dns-query
    fallback:
      - https://cloudflare-dns.com/dns-query
      - https://dns.google/dns-query
    fallback-filter:
      geoip: true
      geoip-code: CN

  proxies:
    {{ proxies }}

  proxy-groups:
    - name: 🚀 节点选择
      type: select
      proxies:
        - DIRECT
        - "@all"
    - name: 🇨🇳 国内回程
      type: select
      proxies:
        - DIRECT
        - "@region:CN"
    - name: 🌍 国际流量
      type: select
      proxies:
        - 🚀 节点选择
        - DIRECT
    - name: 📺 流媒体
      type: select
      proxies:
        - 🚀 节点选择
        - "@tag:streaming"
        - DIRECT
    - name: 🛑 广告拦截
      type: select
      proxies:
        - REJECT
        - DIRECT
    - name: 🐟 漏网之鱼
      type: select
      proxies:
        - 🚀 节点选择
        - DIRECT
        - "@all"

  rules:
    {{ rules_common }}
    {{ rules_personal }}
    - GEOIP,CN,🇨🇳 国内回程
    - MATCH,🐟 漏网之鱼
