# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, coverage profiles, and other test artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov
local-build/

# Go workspace files
go.work
go.work.sum

# Local runtime data and database files
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.log

# Environment and private config
.env
# Root config.yaml: the binary auto-generates it in the CWD on first run (the
# documented run dir is the repo root), so it lands here with jwt_secret + the
# AES-GCM encryption key. Must never be committed.
/config.yaml
config/config.yaml
config/users.yaml
config/xui_panels.yaml
config/saml.yaml
config/saml-sp.crt
config/saml-sp.key
# Rulesets / templates released by the binary on first run (see
# internal/seed/). Canonical sources live in internal/seed/files/.
config/rulesets/
config/templates/

# Frontend dependencies and build output
node_modules/

# Frontend build output is generated; only the embed placeholder is tracked.
internal/web/dist/*
!internal/web/dist/.gitkeep

# TypeScript incremental build cache — regenerated on every build.
web-react/tsconfig.tsbuildinfo

# Reference YAML containing real credentials - never commit.
user_*.yaml
# Local-only reference / scratch space for real configs; never committed.
samples/
private/

# Standalone build artifacts in the repo root (we only ship binaries
# under local-build/ or from CI). Catches stray reset-admin-password.exe
# / migrate-db-v2.exe etc. — the broader *.exe rule above misses files
# without the .exe suffix on non-Windows hosts.
/psp
/migrate-db-v2*
/reset-admin-password*

# Editor/IDE
.idea/
.vscode/
.claude/
CLAUDE.md

# Scratch files used by the assistant to feed multi-line commit messages
# to `git commit -F`. Should never end up tracked.
.git-commit-msg.tmp
