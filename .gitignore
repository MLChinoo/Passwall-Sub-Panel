# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, coverage profiles, and other test artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov
local-build/

# Go workspace files
go.work
go.work.sum

# Local runtime data and database files
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.log

# Environment and private config
.env
config/config.yaml
config/users.yaml
config/xui_panels.yaml
config/saml.yaml
config/saml-sp.crt
config/saml-sp.key
# Rulesets / templates released by the binary on first run (see
# internal/seed/). Canonical sources live in internal/seed/files/.
config/rulesets/
config/templates/

# Frontend dependencies and build output
node_modules/

# Frontend build output is generated; only the embed placeholder is tracked.
internal/web/dist/*
!internal/web/dist/.gitkeep

# Reference YAML containing real credentials - never commit.
user_*.yaml
samples/
private/

# Editor/IDE
.idea/
.vscode/
.claude/
CLAUDE.md
